{
  "manifest_version": 3,
  "name": "ClawAI",
  "version": "1.0",
  "description": "AI Reader - 选中文本获取解释",
  "permissions": ["contextMenus", "activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "bg.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["cs.js"]
    }
  ]
}
